{
  "name": "tab-utils-extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir popup dev",
    "test": "node --test test/*.test.mjs",
    "build": "pnpm build:popup && pnpm package:chrome && pnpm package:firefox",
    "build:popup": "pnpm --dir popup exec vite build",
    "build:chrome": "pnpm build:popup && pnpm package:chrome",
    "build:firefox": "pnpm build:popup && pnpm package:firefox",
    "package:chrome": "node scripts/package-extension.mjs chrome",
    "package:firefox": "node scripts/package-extension.mjs firefox"
  }
}
